# ── Server Configuration ──────────────────────────────────────
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.com

# ── Database ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_at_least_32_chars_long
JWT_EXPIRES_IN=7d

# ── Video Conferencing (Jitsi) ───────────────────────────────
# Unique prefix for room generation
JITSI_ROOM_PREFIX=hackhive-meeting-

# ── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Meeting Scheduler <noreply@example.com>

# ── Google Calendar Integration ──────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-api-domain.com/api/calendar/callback

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
